# Forge Builder configuration
# Copy to .env and fill in your values

# Required
FORGE_GITHUB_REPO=youruser/forge
FORGE_REPO_DIR=~/forge

# API keys — set whichever providers you use
ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=...
# GROQ_API_KEY=gsk_...

# Budget controls
FORGE_DAILY_BUDGET=5.00          # Max USD per day
FORGE_PER_ISSUE_BUDGET=1.50      # Max USD per issue before downgrading

# Model config: "auto" picks by labels/budget, or set a default model
FORGE_MODEL_STRATEGY=auto
FORGE_DEFAULT_MODEL=claude-sonnet-4-6
# FORGE_AIDER_EXTRA_ARGS=--no-stream

# Ollama model for free local LLM judge (used to validate diffs)
# FORGE_OLLAMA_MODEL=qwen2.5-coder:7b

# Schedule: only build during these UTC hours (empty = always)
# Example: overnight only (10pm-6am UTC)
# FORGE_ACTIVE_HOURS=22-06

# Polling interval in seconds (default: 300 = 5 min)
FORGE_POLL_INTERVAL=300

# Budget log location
FORGE_BUDGET_LOG=/opt/forge/infra/builder/budget.jsonl

# Telegram bot (optional — enables remote control)
# 1. Message @BotFather → /newbot → copy token
# 2. Send a message to the bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat_id
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Auto-deploys on push to main via GitHub Actions (see deploy-builder.yml)
